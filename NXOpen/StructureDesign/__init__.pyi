    def RemoveFeaturesInsideMountingFeetComponents(self, components: typing.List[Assemblies.Component]) -> None: ...
    def RemoveFeaturesInsideBoltedConnectionComponents(self, components: typing.List[Assemblies.Component]) -> None: ...
    def RemoveFeaturesInsideStiffenerComponents(self, components: typing.List[Assemblies.Component]) -> None: ...
