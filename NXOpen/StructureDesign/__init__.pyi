from ...NXOpen import *

import typing
import enum

class StructureDesignSession(Utilities.NXRemotableObject):
    def __init__(self, owner: Session) -> None: ...
    def Tag(self) -> Tag: ...

    @property
    def ContextMenu(self) -> StructureDesign.ContextMenu: ...
    @ContextMenu.setter
    def ContextMenu(self, value: StructureDesign.ContextMenu) -> None: ...


class NamespaceDoc(System.Object):
    def __init__(self) -> None: ...


class FrameTaskEnvironment(Utilities.NXRemotableObject):
    def __init__(self, owner: Session) -> None: ...
    def Enter(self) -> None: ...
    def Exit(self) -> None: ...
    def SetCancelled(self) -> None: ...
    def Edit(self, feature: Features.StructureDesign.SuperFrame) -> None: ...
    def Tag(self) -> Tag: ...

    @property
    def ActiveFeature(self) -> Features.StructureDesign.SuperFrame: ...
    @ActiveFeature.setter
    def ActiveFeature(self, value: Features.StructureDesign.SuperFrame) -> None: ...
    @property
    def BaseType(self) -> Features.StructureDesign.SuperFrameBuilder.BaseTypes: ...
    @BaseType.setter
    def BaseType(self, value: Features.StructureDesign.SuperFrameBuilder.BaseTypes) -> None: ...
    @property
    def TransformType(self) -> Features.StructureDesign.SuperFrameBuilder.TransformTypes: ...
    @TransformType.setter
    def TransformType(self, value: Features.StructureDesign.SuperFrameBuilder.TransformTypes) -> None: ...


