    def SpecifiedFillColor(self, value: NXColor) -> None: ...


    class DisplayMethod(enum.Enum):
        ExceedingRange= 0
        ExceedingDefinedRange= 1
        RangeAreas= 2
    

    class AmountOfColors(enum.Enum):
        Two= 0
        Three= 1
    

