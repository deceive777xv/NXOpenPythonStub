    @property
    def Range2Number(self) -> float: ...
    @Range2Number.setter
    def Range2Number(self, value: float) -> None: ...
    @property
    def Range3Color(self) -> NXColor: ...
    @Range3Color.setter
    def Range3Color(self, value: NXColor) -> None: ...
    @property
    def SelectedColorCount(self) -> CableRouter.NetworkUtilizationSettingsBuilder.AmountOfColors: ...
    @SelectedColorCount.setter
    def SelectedColorCount(self, value: CableRouter.NetworkUtilizationSettingsBuilder.AmountOfColors) -> None: ...
    @property
    def SpecifiedFillAmount(self) -> float: ...
